# Synced to Longleaf via `make sync`
# Everything listed here is EXCLUDED from the transfer.

# Python
.venv
__pycache__
*.pyc
*.pyo

# Large local-only data
checkpoints
snapshots
data
figures

# Git (Longleaf doesn't need repo history)
.git

# Notebooks (run locally, not on cluster)
notebooks
*.ipynb

# SLURM logs (generated on cluster, pulled separately)
longleaf/logs

# macOS
.DS_Store

# IDE / editor
.vscode
.idea
*.swp

# Claude
.claude
